{
  "name": "belouga-tournament",
  "version": "1.7.4",
  "description": "Production-ready e-sports tournament management platform with Discord auth, Stripe payments, and an admin back office",
  "homepage": "https://github.com/henchoznoe/BelougaTournament",
  "bugs": {
    "url": "https://github.com/henchoznoe/BelougaTournament/issues",
    "email": "henchoznoe@gmail.com"
  },
  "license": "MIT",
  "author": "Noé Henchoz <henchoznoe@gmail.com> (https://henchoznoe.ch/)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henchoznoe/BelougaTournament.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "start": "next start",
    "prepare": "lefthook install",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "check:all": "biome check --write . && knip",
    "check:com": "biome check --write . && knip && vitest run && tsc --noEmit && next build",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:deploy": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "stripe:listen": "tsx scripts/stripe-listen.ts",
    "stripe:listen:live": "tsx scripts/stripe-listen.ts --live"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "isomorphic-dompurify": "^3.15.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-quill-new": "^3.8.3",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "knip": "^6.15.0",
    "lefthook": "^2.1.9",
    "postcss": "^8.5.15",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "private": true
}
