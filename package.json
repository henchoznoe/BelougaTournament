{
  "name": "belouga-tournament",
  "version": "1.0.1",
  "description": "Production-ready e-sports tournament management platform with Discord auth, Stripe payments, and an admin back office",
  "homepage": "https://github.com/henchoznoe/BelougaTournament",
  "bugs": {
    "url": "https://github.com/henchoznoe/BelougaTournament/issues",
    "email": "henchoznoe@gmail.com"
  },
  "license": "MIT",
  "author": "Noé Henchoz <henchoznoe@gmail.com> (https://henchoznoe.ch/)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henchoznoe/BelougaTournament.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "check:all": "biome check --write . && knip",
    "check:com": "biome check --write . && knip && vitest run && tsc --noEmit && next build",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:deploy": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "stripe:listen": "tsx scripts/stripe-listen.ts",
    "stripe:listen:live": "tsx scripts/stripe-listen.ts --live"
  },
  "lint-staged": {
    "*.{ts,tsx,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "isomorphic-dompurify": "^3.10.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-quill-new": "^3.8.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "knip": "^6.6.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "private": true
}
