# File: .env.example
# Title: Environment Variable Template
# Description: Template for environment variables. Copy this to .env for local development.
# Last modified: 2025-12-05
#

# ==============================================================================
# GENERAL APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=development

# ==============================================================================
# SECURITY / JWT SETTINGS
# To generate a random key, run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==============================================================================
JWT_SECRET_KEY=

# ==============================================================================
# DATABASE SETUP
# ==============================================================================
# Pooled for PrismaClient (port 6543 with pgBouncer and no SSL)
DATABASE_URL=
# Direct for Prisma CLI (port 5432 without pgBouncer)
DIRECT_URL=
# Default SUPERADMIN credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ==============================================================================
# EMAIL SETTINGS
# ==============================================================================
RESEND_API_KEY=
RESEND_FROM=

# ==============================================================================
# STORAGE SETTINGS
# ==============================================================================
# Retrieve it from Vercel project settings
BLOB_READ_WRITE_TOKEN=

# ==============================================================================
# PUBLIC ENVIRONMENT VARIABLES
# ==============================================================================
# Domain of the website
NEXT_PUBLIC_TWITCH_PARENT=
# Default twitch stream URL used in the website and all tournaments
NEXT_PUBLIC_DEFAULT_STREAM_URL=
NEXT_PUBLIC_APP_URL="http://localhost:3000"
