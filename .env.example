# File: .env
# Title: Environment Variable Template
# Description: Template for environment variables. Copy this to .env for local development.
# Last modified: 2025-12-08
#

# ==============================================================================
# GENERAL APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=development

# ==============================================================================
# DATABASE SETUP
# ==============================================================================
# Pooled for PrismaClient (port 6543 with pgBouncer and no SSL)
DATABASE_URL=""
# Direct for Prisma CLI (port 5432 without pgBouncer)
DIRECT_URL=""
# Default SUPERADMIN mail
ADMIN_EMAIL=""

# ==============================================================================
# BETTER AUTH SETTINGS
# ==============================================================================
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ==============================================================================
# OAUTH PROVIDERS
# ==============================================================================
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ==============================================================================
# EMAIL SETTINGS
# ==============================================================================
RESEND_API_KEY="re_..."
RESEND_FROM="Name here <noreply@example.com>"

# ==============================================================================
# STORAGE SETTINGS
# ==============================================================================
# Retrieve it from Vercel project settings
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ==============================================================================
# PUBLIC ENVIRONMENT VARIABLES
# ==============================================================================
# Domain of the website used for twitch embeds
NEXT_PUBLIC_TWITCH_PARENT=""
# Default twitch stream URL used in the website and all tournaments
NEXT_PUBLIC_DEFAULT_STREAM_URL="https://twitch.tv/..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"
