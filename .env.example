# ==============================================================================
# GENERAL APPLICATION SETTINGS
# ==============================================================================
NODE_ENV="development"

# ==============================================================================
# BETTER AUTH SETTINGS
# ==============================================================================
# Generate a random secret using `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=""

# ==============================================================================
# RESEND SETTINGS
# ==============================================================================
RESEND_API_KEY=""

# ==============================================================================
# OAUTH PROVIDERS
# ==============================================================================
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ==============================================================================
# DATABASE SETUP
# ==============================================================================
# Pooled for PrismaClient (port 6543 with pgBouncer and no SSL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/belouga_tournament"
# Direct for Prisma CLI (port 5432 without pgBouncer)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/belouga_tournament"

# ==============================================================================
# STORAGE SETTINGS (Vercel Blob)
# ==============================================================================
BLOB_READ_WRITE_TOKEN=""

# ==============================================================================
# STRIPE SETTINGS
# ==============================================================================
STRIPE_SECRET_KEY=""
# Injected by `pnpm stripe:listen`
STRIPE_WEBHOOK_SECRET=""

# ==============================================================================
# SEED SETTINGS
# ==============================================================================
# Comma-separated list of admin and super admin emails (used by prisma/seed-admin.ts)
ADMIN_EMAILS=""
SUPER_ADMIN_EMAILS=""

# ==============================================================================
# SENTRY SETTINGS
# ==============================================================================
# Server-side DSN (same value as NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=""
# Org and project slugs from sentry.io (used by withSentryConfig in next.config.ts)
SENTRY_ORG=""
SENTRY_PROJECT=""
# Auth token for source map upload at build time — only needed for local `pnpm build`
# Generate at: https://sentry.io/settings/auth-tokens/ (scopes: project:releases + org:read)
SENTRY_AUTH_TOKEN=""


# ==============================================================================
# PUBLIC ENVIRONMENT VARIABLES
# ==============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SENTRY_DSN=""
