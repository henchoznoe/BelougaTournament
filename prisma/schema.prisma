generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TournamentFormat {
  SOLO
  TEAM
}

enum FieldType {
  TEXT
  NUMBER
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RegistrationType {
  FREE
  PAID
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  NOT_REQUIRED
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
  FORFEITED
}

enum RefundPolicyType {
  NONE
  BEFORE_DEADLINE
}

enum DonationType {
  FIXED
  FREE
}

enum PaymentProvider {
  STRIPE
}

model User {
  id            String                   @id @default(uuid())
  name          String
  displayName   String                   @default("")
  email         String                   @unique
  emailVerified Boolean
  image         String?
  discordId     String?                  @unique
  createdAt     DateTime                 @default(now())
  lastLoginAt   DateTime?
  updatedAt     DateTime                 @updatedAt
  role          Role                     @default(USER)
  bannedAt      DateTime?
  bannedUntil   DateTime?
  banReason     String?
  sessions      Session[]
  accounts      Account[]
  registrations TournamentRegistration[]
  captainOf     Team[]                   @relation("TeamCaptain")
  teamMembers   TeamMember[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Tournament {
  id                String                   @id @default(uuid())
  title             String
  slug              String                   @unique
  description       String
  startDate         DateTime
  endDate           DateTime
  registrationOpen  DateTime
  registrationClose DateTime
  maxTeams          Int?
  format            TournamentFormat
  teamSize          Int                      @default(1)
  games             String[] // e.g. ["Valorant", "Rocket League"] — at least one required
  imageUrls         String[] // Tournament images (Vercel Blob URLs)
  rules             String? // Full tournament ruleset
  prize             String? // Cash prize or rewards
  registrationType  RegistrationType         @default(FREE)
  entryFeeAmount    Int?
  entryFeeCurrency  String? // ISO currency code, V1 uses CHF only
  refundPolicyType  RefundPolicyType         @default(NONE)
  refundDeadlineDays Int?
  toornamentId      String?
  streamUrl         String? // Optional per-tournament stream URL override
  teamLogoEnabled   Boolean                  @default(false)
  donationEnabled   Boolean                  @default(false)
  donationType      DonationType?
  donationFixedAmount Int?
  donationMinAmount Int?
  status            TournamentStatus         @default(DRAFT)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  fields            TournamentField[]
  toornamentStages  ToornamentStage[]
  teams             Team[]
  registrations     TournamentRegistration[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model ToornamentStage {
  id           String     @id @default(uuid())
  name         String // Display label (e.g. "Poules", "Playoffs")
  stageId      String // Toornament stage ID (e.g. "618983668512789184")
  number       Int        @default(0) // Display order
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model TournamentField {
  id           String     @id @default(uuid())
  label        String
  type         FieldType
  required     Boolean    @default(true)
  order        Int        @default(0)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Team {
  id           String                  @id @default(uuid())
  name         String
  logoUrl      String?
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  captainId    String
  captain      User                    @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: Cascade)
  isFull       Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  members      TeamMember[]
  registrations TournamentRegistration[]

  @@unique([name, tournamentId])
  @@map("team")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@map("team_member")
}

model TournamentRegistration {
  id                String             @id @default(uuid())
  tournamentId      String
  tournament        Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldValues       Json               @default("{}")
  status            RegistrationStatus @default(CONFIRMED)
  paymentStatus     PaymentStatus      @default(NOT_REQUIRED)
  paymentRequiredSnapshot Boolean      @default(false)
  entryFeeAmountSnapshot Int?
  entryFeeCurrencySnapshot String?
  refundDeadlineDaysSnapshot Int?
  donationAmountSnapshot Int?
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  payments          Payment[]

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([status, expiresAt])
  @@index([createdAt])
  @@map("tournament_registration")
}

model Payment {
  id                      String             @id @default(uuid())
  registrationId          String
  registration            TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  provider                PaymentProvider
  status                  PaymentStatus      @default(PENDING)
  amount                  Int
  currency                String
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId   String?            @unique
  stripeChargeId          String?            @unique
  stripeCustomerId        String?
  stripeFee               Int?
  donationAmount          Int?
  refundAmount            Int?
  paidAt                  DateTime?
  refundedAt              DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([registrationId, status])
  @@map("payment")
}

model StripeWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  payload       Json?
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([type, processedAt])
  @@map("stripe_webhook_event")
}

model GlobalSettings {
  id        Int     @id @default(1)
  logoUrl   String?
  twitchUsername String?
  twitchUrl String?
  instagramUrl   String?
  tiktokUrl String?
  youtubeUrl String?
  discordUrl String?
  feature1Title       String?
  feature1Description String?
  feature2Title       String?
  feature2Description String?
  feature3Title       String?
  feature3Description String?

  @@map("global_settings")
}

model Sponsor {
  id             String   @id @default(uuid())
  name           String
  imageUrls      String[]
  url            String?
  enabled        Boolean  @default(true)
  supportedSince DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("sponsor")
}
