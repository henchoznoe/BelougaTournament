generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum TournamentFormat {
  SOLO
  TEAM
}

enum FieldType {
  TEXT
  NUMBER
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLIST
}

model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  role          Role         @default(ADMIN)
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}


enum Visibility {
  PUBLIC
  PRIVATE
}

model Tournament {
  id                String            @id @default(uuid())
  title             String
  slug              String            @unique
  description       String
  startDate         DateTime
  endDate           DateTime
  registrationOpen  DateTime
  registrationClose DateTime
  maxParticipants   Int?
  format            TournamentFormat
  teamSize          Int               @default(1)
  challongeId       String?
  streamUrl         String
  autoApprove       Boolean           @default(false)
  visibility        Visibility        @default(PRIVATE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  fields             TournamentField[]
  registrations     Registration[]
}

model TournamentField {
  id           String       @id @default(uuid())
  label        String
  type         FieldType
  required     Boolean      @default(true)
  order        Int          @default(0)
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerData   PlayerData[]
}

model Registration {
  id           String     @id @default(uuid())
  teamName     String?
  contactEmail String
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players      Player[]

  cancellationToken String @default(uuid())

  @@unique([tournamentId, contactEmail])
}

model Player {
  id             String       @id @default(uuid())
  nickname       String
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  data           PlayerData[]
}

model PlayerData {
  id                String          @id @default(uuid())
  value             String
  playerId          String
  player            Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentFieldId String
  tournamentField   TournamentField @relation(fields: [tournamentFieldId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id            Int     @id @default(1)
  logoUrl         String?
  socialDiscord   String?
  socialTiktok    String?
  socialTwitch    String?
  socialInstagram String?
  socialYoutube   String?
}
