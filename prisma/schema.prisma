generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  SUPERADMIN
}

enum TournamentFormat {
  SOLO
  TEAM
}

enum FieldType {
  TEXT
  NUMBER
  SELECT
  CHECKBOX
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLIST
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tournament {
  id                String            @id @default(uuid())
  title             String
  slug              String            @unique
  description       String
  startDate         DateTime
  endDate           DateTime
  registrationOpen  DateTime
  registrationClose DateTime
  maxParticipants   Int?
  format            TournamentFormat
  teamSize          Int               @default(1)
  challongeId       String?
  streamUrl         String            @default("https://twitch.tv/quentadoulive")
  autoApprove       Boolean           @default(false)
  isArchived        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  fields             TournamentField[]
  registrations     Registration[]
}

model TournamentField {
  id           String       @id @default(uuid())
  label        String
  type         FieldType
  required     Boolean      @default(true)
  order        Int          @default(0)
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerData   PlayerData[]
}

model Registration {
  id           String     @id @default(uuid())
  teamName     String?
  contactEmail String
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players      Player[]

  cancellationToken String @default(uuid())

  @@unique([tournamentId, contactEmail])
}

model Player {
  id             String       @id @default(uuid())
  nickname       String
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  data           PlayerData[]
}

model PlayerData {
  id                String          @id @default(uuid())
  value             String
  playerId          String
  player            Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentFieldId String
  tournamentField   TournamentField @relation(fields: [tournamentFieldId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id            Int     @id @default(1)
  logoUrl         String?
  socialDiscord   String?
  socialTiktok    String?
  socialTwitch    String?
  socialInstagram String?
  socialYoutube   String?
  statsYears       String?
  statsPlayers     String?
  statsTournaments String?
  statsMatches     String?
}
