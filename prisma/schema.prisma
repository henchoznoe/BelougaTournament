generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum TournamentFormat {
  SOLO
  TEAM
}

enum FieldType {
  TEXT
  NUMBER
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String                   @id @default(uuid())
  name          String
  displayName   String                   @default("")
  email         String                   @unique
  emailVerified Boolean
  image         String?
  discordId     String?                  @unique
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  role          Role                     @default(USER)
  bannedUntil   DateTime?
  banReason     String?
  sessions      Session[]
  accounts      Account[]
  registrations TournamentRegistration[]
  captainOf     Team[]                   @relation("TeamCaptain")
  teamMembers   TeamMember[]
  adminOf       AdminAssignment[]        @relation("AssignedAdmin")

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Tournament {
  id                String                   @id @default(uuid())
  title             String
  slug              String                   @unique
  description       String
  startDate         DateTime
  endDate           DateTime
  registrationOpen  DateTime
  registrationClose DateTime
  maxTeams          Int?
  format            TournamentFormat
  teamSize          Int                      @default(1)
  game              String? // e.g. Valorant, Rocket League
  imageUrl          String? // Tournament banner image
  rules             String? // Full tournament ruleset
  prize             String? // Cash prize or rewards
  toornamentId      String?
  streamUrl         String? // Optional per-tournament stream URL override
  autoApprove       Boolean                  @default(false)
  status            TournamentStatus         @default(DRAFT)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  fields            TournamentField[]
  teams             Team[]
  registrations     TournamentRegistration[]
  adminAssignments  AdminAssignment[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model TournamentField {
  id           String     @id @default(uuid())
  label        String
  type         FieldType
  required     Boolean    @default(true)
  order        Int        @default(0)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Team {
  id           String                  @id @default(uuid())
  name         String
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  captainId    String
  captain      User                    @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: Cascade)
  isFull       Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  members      TeamMember[]
  registration TournamentRegistration?

  @@unique([name, tournamentId])
  @@map("team")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@map("team_member")
}

model TournamentRegistration {
  id                String             @id @default(uuid())
  tournamentId      String
  tournament        Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId            String?            @unique
  team              Team?              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldValues       Json               @default("{}")
  status            RegistrationStatus @default(PENDING)
  createdAt         DateTime           @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([createdAt])
  @@map("tournament_registration")
}

model AdminAssignment {
  id           String     @id @default(uuid())
  adminId      String
  admin        User       @relation("AssignedAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@unique([adminId, tournamentId])
  @@map("admin_assignment")
}

model GlobalSettings {
  id        Int     @id @default(1)
  logoUrl   String?
  twitchUsername String?
  twitchUrl String?
  instagramUrl   String?
  tiktokUrl String?
  youtubeUrl String?
  discordUrl String?
  feature1Title       String?
  feature1Description String?
  feature2Title       String?
  feature2Description String?
  feature3Title       String?
  feature3Description String?

  @@map("global_settings")
}

model Sponsor {
  id             String   @id @default(uuid())
  name           String
  imageUrls      String[]
  url            String?
  supportedSince DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("sponsor")
}
